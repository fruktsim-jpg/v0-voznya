# ВОЗНЯ website — environment variables
#
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# In production (Vercel) set DATABASE_URL in Project Settings → Environment Variables.
# For Cursor Cloud Agents, add it under Cloud Agents → Secrets.

# ---------------------------------------------------------------------------
# PostgreSQL connection string to the voznya-bot database.
#
# Powers the live community dashboard (/live) and the homepage live stats.
# The bot stores its URL as an asyncpg DSN (postgresql+asyncpg://...); this app
# also accepts that form and strips the "+asyncpg" driver suffix automatically.
#
# The database must be reachable from where the site runs (Vercel) — i.e. a
# public host/port, NOT the docker-compose internal host "db". Add sslmode=require
# for managed providers (Neon, Supabase, RDS, etc.).
#
# Examples:
#   DATABASE_URL=postgresql://voznya:password@db.example.com:5432/voznya?sslmode=require
#   DATABASE_URL=postgresql+asyncpg://voznya:password@1.2.3.4:5432/voznya
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://voznya:password@host:5432/voznya?sslmode=require

# ---------------------------------------------------------------------------
# Telegram Login
#
# The bot is the single source of truth for users; the site only verifies that
# a login genuinely comes from Telegram for this bot and issues a session.
#
# TELEGRAM_BOT_TOKEN  — same token the bot uses (from @BotFather). Used server
#                       side to verify the Login Widget HMAC. Keep it secret.
# NEXT_PUBLIC_TELEGRAM_BOT_ID — the integer part of the token BEFORE the ":".
#                       Public (it's only the bot id). Used by the branded login
#                       button to open Telegram's verified auth popup via
#                       window.Telegram.Login.auth({ bot_id }). Required for the
#                       custom "Войти через Telegram" button to work.
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME — the bot's @username WITHOUT the @. Public.
#                       REQUIRED for OIDC login: a first-time Telegram OIDC user
#                       is sent to /link, which builds the bot deep-link
#                       t.me/<username>?start=link_<token> to confirm the account
#                       (the OIDC `sub` is opaque and is NOT the Telegram id, so
#                       the real users.user_id is resolved via account_links).
# AUTH_SECRET         — random string (>= 32 chars) used to sign session JWTs.
#                       Generate with: openssl rand -base64 48
# AUTH_COOKIE_NAME    — optional, defaults to "voznya_session".
#
# IMPORTANT: in @BotFather run /setdomain and point it to this site's domain,
# otherwise the Login popup will refuse to authorize.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456:your-bot-token
NEXT_PUBLIC_TELEGRAM_BOT_ID=123456
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
AUTH_SECRET=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# Admin panel bootstrap
#
# ADMIN_IDS — comma-separated Telegram user ids, the SAME value the bot uses for
#             its emergency superusers (e.g. "111111111,222222222"). The site
#             uses this ONLY to gate a one-time owner bootstrap: a logged-in user
#             whose id is here can self-assign the `owner` role at /admin while
#             the admin_roles table is still empty (POST /api/admin/bootstrap-owner).
#             Being in ADMIN_IDS grants NO panel access by itself — day-to-day
#             rights come purely from the admin_roles table. After the first owner
#             exists the bootstrap is permanently disabled. Server-only (no
#             NEXT_PUBLIC_ prefix), so it is never exposed to the browser.
# ---------------------------------------------------------------------------
ADMIN_IDS=


# ---------------------------------------------------------------------------
# Telegram OpenID Connect (OIDC) — preferred login flow.
#
# When all three vars below are set, the branded "Войти через Telegram" button
# uses the Authorization Code + PKCE flow against oauth.telegram.org instead of
# the classic Login Widget popup. The classic widget stays as an automatic
# fallback when these are NOT set (so login never breaks during rollout).
#
# Provider metadata is fixed (issuer https://oauth.telegram.org) and discovered
# automatically; the *_ISSUER/*_ENDPOINT/*_JWKS_URI/*_SCOPE overrides below are
# optional and only needed if Telegram ever changes its endpoints.
#
# Get CLIENT_ID / CLIENT_SECRET and register the REDIRECT_URI in @BotFather
# under the bot's Login / OAuth settings. The redirect URI must point to:
#   https://<your-domain>/api/auth/telegram/oidc/callback
#
# TELEGRAM_OIDC_CLIENT_ID     — public OAuth client id.
# TELEGRAM_OIDC_CLIENT_SECRET — OAuth client secret. Keep it secret (server only).
# TELEGRAM_OIDC_REDIRECT_URI  — must EXACTLY match the URI registered in BotFather.
# ---------------------------------------------------------------------------
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
TELEGRAM_OIDC_REDIRECT_URI=https://voznya.nl/api/auth/telegram/oidc/callback

# ---------------------------------------------------------------------------
# Открытие кейсов с сайта (мост к боту)
#
# Сайт НЕ открывает кейсы сам и НЕ дублирует экономику: /api/cases/open
# проксирует запрос во внутренний HTTP-API бота, где живёт единственная
# функция open_case (CSPRNG, блокировки, списание ешек, выдача награды и
# pending-конвейер Telegram Gifts/Premium, леджер открытий).
#
# BOT_INTERNAL_URL    — базовый URL внутреннего API бота. В docker-сети это
#                       http://bot:8081. ВАЖНО: бот должен быть СЕТЕВО доступен
#                       оттуда, где запущен сайт. Если сайт на Vercel, а бот —
#                       на отдельном VPS, нужен публично доступный (желательно
#                       приватный/закрытый фаерволом) адрес, например
#                       https://bot.voznya.nl. Порт наружу публиковать только
#                       под защитой секрета ниже.
# BOT_INTERNAL_SECRET — общий секрет, ТОТ ЖЕ, что INTERNAL_API_SECRET у бота.
#                       Без него открытие с сайта отключено (роут вернёт 503).
#
# Если переменные не заданы — витрина кейсов работает, но кнопка «Открыть»
# покажет «временно недоступно, открой в боте: /кейсы».
# ---------------------------------------------------------------------------
BOT_INTERNAL_URL=
BOT_INTERNAL_SECRET=

# Optional provider overrides (defaults shown — leave unset unless Telegram changes them):
# TELEGRAM_OIDC_ISSUER=https://oauth.telegram.org
# TELEGRAM_OIDC_AUTH_ENDPOINT=https://oauth.telegram.org/auth
# TELEGRAM_OIDC_TOKEN_ENDPOINT=https://oauth.telegram.org/token
# TELEGRAM_OIDC_JWKS_URI=https://oauth.telegram.org/.well-known/jwks.json
# TELEGRAM_OIDC_SCOPE=openid profile




